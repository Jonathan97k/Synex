# Copy to .env and fill in. Never commit the real .env file.

# MongoDB Atlas connection string — stores your project list (name, repo, branch).
# You can reuse an existing cluster; just point this at a database named "synex".
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/synex?retryWrites=true&w=majority

# Long random string used to sign your login session.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Your login for this tool — you are the only person who should have this.
ADMIN_USERNAME=jonathan
ADMIN_PASSWORD=choose-a-strong-password

# A GitHub Personal Access Token with "repo" scope.
# Used to push files to whichever repo you select in the tool.
# Create one at: github.com/settings/tokens (classic token, "repo" scope checked)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

PORT=3000
